# Grok API (xAI) - FREE
# Sign up at: https://console.x.ai
VITE_GROK_API_KEY=your_grok_api_key_here

# Finnhub API - FREE TIER (60 calls/minute)
# Sign up at: https://finnhub.io
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI - FREE TIER (100 requests/day)
# Sign up at: https://newsapi.org
VITE_NEWS_API_KEY=your_newsapi_key_here

# Twelvedata API - FREE TIER (800 requests/day)
# Sign up at: https://twelvedata.com
VITE_TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Polygon.IO API - FREE TIER (5 calls/minute)
# Sign up at: https://polygon.io
VITE_POLYGON_API_KEY=your_polygon_api_key_here

# Application Configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_ENV=development
